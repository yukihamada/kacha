    ;; Active GPIO pin assignments (KAGI Lite firmware):
    ;; GPIO1  → VBUS_ADC (USB停電検知, 100K分圧)
    ;; GPIO2  → BUTTON_OK (SW2 I'm OK ボタン, プルアップ)
    ;; GPIO3  → DOOR_SW (MC-38磁気センサー, プルアップ)
    ;; GPIO4  → RADAR_OUT (LD2410B OUT HIGH=在室)
    ;; GPIO8  → I2C_SDA (SHT40 + ATECC608A)
    ;; GPIO9  → I2C_SCL (SHT40 + ATECC608A)
    ;; GPIO14 → RADAR_TX (UART1 TX → LD2410B RX)
    ;; GPIO15 → RADAR_RX (UART1 RX ← LD2410B TX)
    ;; GPIO17 → BUZZER (BZ1 active buzzer HIGH=ON)
    ;; GPIO19 → USB_D- (ファームウェア書き込み)
    ;; GPIO20 → USB_D+ (ファームウェア書き込み)
    ;; GPIO38 → WS2812_DATA (D1 → D1b デイジーチェーン)
  )

